{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch DigiSign (.NET Framework)",
            "type": "clr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/../../Build/Digisign/DigiSign.exe",
            "args": [],
            "cwd": "${workspaceFolder}/../../Build/Digisign",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": ".NET Framework Attach",
            "type": "clr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
